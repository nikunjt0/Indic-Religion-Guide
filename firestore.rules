rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write only their own profile. Admin SDK bypasses these rules.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Personal chat history lives in a subcollection, same ownership rule.
      match /chats/{chatId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Ritual guides and source metadata are public reads for any signed-in user
    // (including anonymous). Writes are server-only.
    match /ritualGuides/{slug} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /sources/{sourceId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Chunks and query audit logs are server-only — admin SDK writes, clients don't read.
    match /chunks/{chunkId} {
      allow read, write: if false;
    }
    match /queries/{queryId} {
      allow read, write: if false;
    }
  }
}
